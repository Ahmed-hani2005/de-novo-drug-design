generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id        String   @id @default(uuid())
  externalId String  @unique
  email     String   @unique
  projects  Project[]
}

model PatientProfile {
  id               String   @id @default(uuid())
  name             String   @default("Anonymous") // اسم المريض
  age              Int
  gender           String
  weight           String
  chronicCondition String   @default("None") // الأمراض المزمنة
  liverFunction    String   @default("Normal")
  kidneyFunction   String   @default("Normal")
  geneticMutation  String?
  projects         Project[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  pdbId       String
  targetName  String?
  status      String   @default("Screening")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  patientId   String?
  patient     PatientProfile? @relation(fields: [patientId], references: [id])
  molecules   Molecule[]
  createdAt   DateTime @default(now())
}

model Molecule {
  id              String   @id @default(uuid())
  smiles          String
  molecularWeight Float
  logP            Float
  hbd             Int
  hba             Int
  tpsa            Float
  qed             Float
  bindingAffinity Float
  toxicityRisk    String
  absorption      Float    @default(0) // New for ADMET
  clearance       Float    @default(0) // New for ADMET
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  isSelected      Boolean  @default(false)
  createdAt       DateTime @default(now())
}
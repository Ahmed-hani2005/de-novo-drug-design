generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id        String   @id @default(uuid())
  externalId String  @unique
  email     String   @unique
  projects  Project[]
}

model PatientProfile {
  id               String   @id @default(uuid())
  name             String   @default("Anonymous")
  age              Int
  gender           String
  weight           String
  
  // الحقول الطبية الجديدة (تأكد إنها موجودة)
  tumorType        String   @default("Lung Cancer")
  cancerStage      String   @default("Stage II")
  chronicCondition String   @default("None")
  previousTreatment String?
  
  liverFunction    String   @default("Normal")
  kidneyFunction   String   @default("Normal")
  geneticMutation  String?
  
  projects         Project[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  pdbId       String
  targetName  String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  patientId   String?
  patient     PatientProfile? @relation(fields: [patientId], references: [id])
  molecules   Molecule[]
  createdAt   DateTime @default(now())
}

model Molecule {
  id              String   @id @default(uuid())
  smiles          String
  source          String   @default("De Novo AI") 
  
  // الخصائص
  molecularWeight Float
  logP            Float
  hbd             Int
  hba             Int
  tpsa            Float
  rotatableBonds  Int      @default(5)
  
  // حقول الأمان (Safety)
  absorption      Float    @default(0)
  clearance       Float    @default(0)
  hERGRisk        String   @default("Low")
  cypInhibition   String   @default("None")
  liverToxRisk    String   @default("Low") // مهم جداً
  
  // حقول الذكاء الاصطناعي
  qed             Float
  bindingAffinity Float
  efficacy        Float
  confidenceScore Float    @default(0.0)
  aiReasoning     String   @default("Analysis pending...") 

  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  createdAt       DateTime @default(now())
}